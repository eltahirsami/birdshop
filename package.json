{
  "name": "smart-pos-system",
  "version": "1.0.0",
  "description": "🧾 Smart POS System",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.smartpos.system",
    "productName": "🧾 Smart POS System",
    "asar": false,
    "npmRebuild": false,
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": true
    },
    "files": [
      "**/*",
      "!.wwebjs_auth",
      "!.wwebjs_cache",
      "!backups",
      "!dist"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "node-cron": "^4.2.1",
    "node-machine-id": "^1.1.12",
    "qrcode-terminal": "^0.12.0",
    "sqlite3": "^5.1.7",
    "whatsapp-web.js": "^1.34.6"
  },
  "devDependencies": {
    "electron": "^41.0.3",
    "electron-builder": "^25.1.8"
  }
}
